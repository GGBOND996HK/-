{
  "expo": {
    "name": "上海敲麻助手",
    "slug": "shanghai-qiaoma-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.local.shanghaiqiaoma",
      "infoPlist": {
        "NSCameraUsageDescription": "用于拍摄自己的麻将手牌并生成出牌推荐。"
      }
    },
    "android": {
      "package": "com.local.shanghaiqiaoma",
      "permissions": [
        "CAMERA"
      ]
    }
  }
}
